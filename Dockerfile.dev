# syntax=docker/dockerfile:1

# ================================
# Build stage
# ================================
FROM oven/bun:1.3.1-alpine AS builder

# Install build dependencies
RUN apk add --no-cache git

# Set working directory
WORKDIR /app

# Copy package files for better layer caching
COPY package.json ./

# Install all dependencies (including dev dependencies for build)
RUN bun install --frozen-lockfile

# Copy source code
COPY . .

# Build the application (if needed)
RUN bun run typecheck

# Remove dev dependencies for production
RUN bun install --frozen-lockfile --production

# ================================
# Production stage
# ================================
FROM oven/bun:1.3.1-alpine AS production

# Install curl for health checks and security updates
RUN apk add --no-cache curl && \
    apk upgrade --no-cache && \
    rm -rf /var/cache/apk/*

# Create non-root user for security
RUN addgroup -g 1001 -S bunjs && \
    adduser -S bunjs -u 1001

# Set working directory
WORKDIR /app

# Copy package files
COPY package.json ./

# Copy production dependencies from builder stage
COPY --from=builder /app/node_modules ./node_modules

# Copy built application code
COPY --from=builder /app/src ./src
COPY --from=builder /app/tsconfig.json ./

# Change ownership to non-root user
RUN chown -R bunjs:bunjs /app
USER bunjs

# Environment variables for production (override with docker run -e)
ENV PORT=3000 \
    BUN_RUNTIME_TRANSPILER_CACHE_PATH=/tmp/bun-cache \
    AWS_SECRET_NAME=sekolahku-mod-api-secret-v-dev

# Expose port
EXPOSE 3000

# Health check with proper configuration
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD curl -f --max-time 10 http://localhost:3000/health || exit 1

# Use exec form for proper signal handling
CMD ["bun", "run", "start"]